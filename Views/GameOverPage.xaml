<Page x:Class="pr16.Views.GameOverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr16.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GameOverPage">

    <Grid Background="#2c3e50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="ИГРА ОКОНЧЕНА" FontSize="32" FontWeight="Bold" Foreground="DarkRed" Margin="0,0,0,30"/>
                <TextBlock Text="Вы погибли в подземелье..." FontSize="20" Foreground="White" Margin="0,0,0,30"/>
                <Button Content="Начать заново" Click="Restart_Click" FontSize="18" Padding="15,5"
                    Background="LightSlateGray" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Page>