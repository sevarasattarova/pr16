<Page x:Class="pr16.Views.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr16.Views"
      mc:Ignorable="d" 
      Title="GamePage" Background="#1e2a36">

    <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- название игры -->
                <RowDefinition Height="Auto"/>
                <!-- этаж и здоровье -->
                <RowDefinition Height="*"/>
                <!-- основная область -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <!-- инвентарь -->
                <ColumnDefinition Width="3*"/>
                <!-- игра -->
                <ColumnDefinition Width="2*"/>
                <!-- лог -->
            </Grid.ColumnDefinitions>

            <!-- Название игры (верх, на всю ширину) -->
            <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#34495e" Padding="10">
                <TextBlock Text="БИТВА СИЛЬНЕЙШИХ" FontSize="24" FontWeight="Bold"
                       Foreground="FloralWhite" HorizontalAlignment="Center"/>
            </Border>

            <!-- Строка статуса: этаж и здоровье -->
            <Border Grid.Row="1" Grid.ColumnSpan="3" Background="#2c3e50" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Этаж: " Foreground="FloralWhite" FontSize="18"/>
                        <TextBlock x:Name="FloorText" Foreground="#f1c40f" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Здоровье: " Foreground="FloralWhite" FontSize="18"/>
                        <TextBlock x:Name="HealthText" Foreground="#e74c3c" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ЛЕВАЯ ПАНЕЛЬ: ИНВЕНТАРЬ (оружие и броня) -->
            <Border Grid.Row="2" Grid.Column="0" Background="#1e2a36" Margin="10" CornerRadius="10">
                <StackPanel Margin="10">
                <TextBlock Text="ИНВЕНТАРЬ" FontSize="20" FontWeight="Bold" Foreground="FloralWhite" 
                           HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Border Background="#34495e" Padding="10" CornerRadius="8" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="ОРУЖИЕ" Foreground="#bdc3c7" FontSize="14"/>
                            <TextBlock x:Name="WeaponText" Foreground="White" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#34495e" Padding="10" CornerRadius="8" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="БРОНЯ" Foreground="#bdc3c7" FontSize="14"/>
                            <TextBlock x:Name="ArmorText" Foreground="White" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ЦЕНТРАЛЬНАЯ ОБЛАСТЬ: САМА ИГРА (события, бой, картинка) -->
            <Border Grid.Row="2" Grid.Column="1" Background="#2c3e50" Margin="10" CornerRadius="15">
                <StackPanel>
                    <Image x:Name="EventImage" Source="/Images/dungeon.png" Width="250" Height="250" 
                       Margin="10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EventDescription" Text="Нажмите 'Исследовать'" Foreground="White" 
                           FontSize="16" TextAlignment="Center" Margin="10" TextWrapping="Wrap"/>
                    <WrapPanel HorizontalAlignment="Center" Margin="10">
                        <Button x:Name="ExploreButton" Content="Исследовать" Click="Explore_Click" 
                            Width="140" Height="45" Margin="5" Background="#27ae60" Foreground="White"
                            FontSize="14" FontWeight="Bold"/>
                        <Button x:Name="AttackButton" Content="Атака" Click="Attack_Click" Visibility="Collapsed"
                            Width="100" Height="45" Margin="5" Background="#e74c3c" Foreground="White"
                            FontSize="14" FontWeight="Bold"/>
                        <Button x:Name="DefendButton" Content="Защита" Click="Defend_Click" Visibility="Collapsed"
                            Width="100" Height="45" Margin="5" Background="#f39c12" Foreground="White"
                            FontSize="14" FontWeight="Bold"/>
                        <Button x:Name="TakeButton" Content="Взять" Click="TakeItem_Click" Visibility="Collapsed"
                            Width="100" Height="45" Margin="5" Background="#2ecc71" Foreground="White"
                            FontSize="14" FontWeight="Bold"/>
                        <Button x:Name="DiscardButton" Content="Выбросить" Click="DiscardItem_Click" Visibility="Collapsed"
                            Width="100" Height="45" Margin="5" Background="#e67e22" Foreground="White"
                            FontSize="14" FontWeight="Bold"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ПРАВАЯ ПАНЕЛЬ: ЛОГИРОВАНИЕ -->
            <Border Grid.Row="2" Grid.Column="2" Background="#1e2a36" Margin="10" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                <TextBlock Text="ЖУРНАЛ СОБЫТИЙ" FontSize="18" FontWeight="Bold" Foreground="FloralWhite"
                           HorizontalAlignment="Center" Margin="10,10,10,5"/>
                    <ListBox x:Name="EventLogList" Grid.Row="1" Background="#2c3e50" BorderThickness="0" 
                         Foreground="White" FontSize="12" Margin="10"/>
                </Grid>
            </Border>
        </Grid>
    </Page>